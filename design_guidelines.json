  "universal_guidelines_for_main_agent": {
    "framework": "React Native Expo (Managed Workflow)",
    "styling": "StyleSheet.create (NO CSS, NO Tailwind/NativeWind unless configured - Assume Standard StyleSheet)",
    "navigation": "Expo Router (File-based routing)",
    "language": "French (Hardcoded strings for now)",
    "safe_area": "Always use SafeAreaView from react-native-safe-area-context",
    "platform_specific": "Handle Platform.OS === 'ios' vs 'android' for shadows and font families",
    "code_structure": "Functional Components with Hooks",
    "data_testid": "Add testID prop to all interactive elements",
    "state_management": "React Context or Zustand (Simple global state)",
    "icons": "Use @expo/vector-icons/Lucide",
    "fonts": "Use expo-font to load Inter/DM Sans",
    "mock_data": "Create a robust mock data file for courses, scholars, and users",
    "image_handling": "Use Expo Image for caching and performance"
  },
  "instructions_to_main_agent": [
    "1. Initialize Expo Router structure in /app directory.",
    "2. Create a global theme context/provider to manage colors and fonts.",
    "3. Build reusable atomic components (Button, Typography, Card, Input) first.",
    "4. Implement the 'AppShell' (Tab Navigation + MiniPlayer Wrapper).",
    "5. Mock data using French lorem ipsum and provided image URLs.",
    "6. Ensure Dark Mode is hardcoded as default (no light mode toggle for MVP).",
    "7. Use 'Inter' font for headings and 'DM Sans' for body text if available, else system sans-serif.",
    "8. STRICTLY follow the color palette: #121212 Background, #04D182 Accent."
  ]
